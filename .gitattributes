# Enforce LF for all auto-detected text files
* text=auto eol=lf

# Python Source
*.py text eol=lf
*.pyw text eol=lf

# Configuration and Documentation
*.md text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.ini text eol=lf

# Exclude Binary Files from modifications
*.pkl binary
*.pyc binary
*.pyd binary
*.so binary
*.dll binary
*.exe binary

# Git Config
.gitignore text eol=lf
.gitattributes text eol=lf
